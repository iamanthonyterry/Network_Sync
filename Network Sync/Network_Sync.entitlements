<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox is OFF (see ENABLE_APP_SANDBOX in build settings).
         NetFS SMB mounting requires direct access to mount(2), which the
         sandbox blocks outright — no entitlement combination works around
         it. This app is distributed internally, not via the Mac App Store,
         so sandboxing isn't required. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
